DATABASE_URL=postgresql://postgres:password@localhost:5432/atom_db
API_PORT=4200
NODE_ENV=development
MCP_SECRET=
JWT_SECRET=

# Google OAuth — leave GOOGLE_CLIENT_ID empty to disable Google login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://your-domain/api/auth/google/callback

# Slack OAuth — leave SLACK_CLIENT_ID empty to disable Slack login
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_CALLBACK_URL=https://your-domain/api/auth/slack/callback
SLACK_ALLOWED_TEAM_ID=

# Frontend URL for CORS and OAuth redirects (leave empty for dev)
FRONTEND_URL=

# First admin user email (seeded on first startup)
ALLOWED_EMAIL=your-email@gmail.com
