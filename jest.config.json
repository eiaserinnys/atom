{
  "extensionsToTreatAsEsm": [".ts"],
  "transform": {
    "^.+\\.tsx?$": [
      "ts-jest",
      {
        "useESM": true,
        "tsconfig": {
          "module": "ESNext",
          "moduleResolution": "bundler",
          "isolatedModules": false
        }
      }
    ]
  },
  "moduleNameMapper": {
    "^(\\.{1,2}/.*)\\.js$": "$1"
  },
  "testEnvironment": "node",
  "testMatch": ["**/?(*.)+(spec|test).[tj]s?(x)"],
  "roots": ["<rootDir>/tests"],
  "testTimeout": 120000
}
